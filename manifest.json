{
  "manifest_version": 3,
  "name": "CleanFeed",
  "version": "3.1",
  "permissions": ["storage", "alarms"],
  "host_permissions": [
    "*://*.twitter.com/*",
    "*://twitter.com/*",
    "*://*.x.com/*",
    "*://x.com/*",
    "*://*.reddit.com/*",
    "*://reddit.com/*",
    "*://*.linkedin.com/*",
    "*://linkedin.com/*",
    "https://cleanfeed.social/*",
    "https://raw.githubusercontent.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.twitter.com/*",
        "*://twitter.com/*",
        "*://*.x.com/*",
        "*://x.com/*",
        "*://*.reddit.com/*",
        "*://reddit.com/*",
        "*://*.linkedin.com/*",
        "*://linkedin.com/*"
      ],
      "js": ["content_isolated.js"],
      "world": "ISOLATED",
      "run_at": "document_idle"
    }
  ]
}